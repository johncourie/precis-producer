# Source PDFs — ignored by default (copyrighted books)
*.pdf

# Public domain PDFs — tracked
!1919-Ellingwood-American-Materia-Medica-Therapeutics-Pharmacognosy.pdf
!5-1898-Felter-Lloyd-Kings-American-Dispensatory.pdf
!Felters_Materia_Medica.pdf
!potterscyclopaed00wreniala.pdf

# Extracted indexes — ignored by default (use _indexes/* not _indexes/ so negation works)
_indexes/*

# Public domain book indexes — tracked
!_indexes/ellingwood.txt
!_indexes/kings.txt
!_indexes/kings_lookup.json
!_indexes/felter_mm.txt
!_indexes/potters.txt

# Generated output
precis/

# Per-run manifest
manifest.json

# Local config (use config.example.json as template)
config.json

# Local book registry (use books.example.json as template)
books.json

# Packaging
*.egg-info/

# Python
__pycache__/
*.pyc

# macOS
.DS_Store
